# ---------------------------------------------------------------------------
# job-auto-apply environment configuration
# Copy this file to `.env` and fill in the values you need.
# ---------------------------------------------------------------------------

# --- LLM: Gemini (primary) ---
# Get a free key at https://aistudio.google.com/app/apikey
# Leave blank to run entirely on a local Ollama model (see below).
GEMINI_API_KEY=

# Which provider to use: auto | gemini | ollama
#   auto   -> use Gemini if GEMINI_API_KEY is set, otherwise Ollama;
#             also fall back to Ollama automatically if a Gemini call fails.
#   gemini -> force Gemini (errors if no key).
#   ollama -> force local Ollama.
LLM_PROVIDER=auto

# Gemini model to use for text/JSON generation.
GEMINI_MODEL=gemini-2.0-flash

# --- LLM: Ollama (local fallback) ---
# Ollama must be running locally. Install from https://ollama.com then:
#   ollama pull llama3.1:8b
OLLAMA_HOST=http://localhost:11434
# Default model balances quality/speed on a laptop without a big GPU.
# If you have 12GB+ VRAM, qwen2.5:14b or mistral-nemo are stronger for
# strict-JSON tasks like scoring. Swap here and pull the model first.
OLLAMA_MODEL=llama3.1:8b
# Per-request timeout (seconds). Long outputs — especially the tailored resume
# LaTeX — can take several minutes on CPU-only machines. Raise if you see
# "Ollama timed out" during resume generation.
OLLAMA_TIMEOUT=600

# --- Job platform credentials ---
# Used only by the browser-automation modules on your own machine.
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
INDEED_EMAIL=
INDEED_PASSWORD=

# --- Storage ---
DB_PATH=./data/jobs.db

# --- Automation tuning (optional; sensible defaults applied if unset) ---
# Directory for the persistent Playwright browser profile (holds your logged-in
# session cookies). Keep this OUT of version control.
BROWSER_PROFILE_DIR=./browser_profiles/default
# Max applications submitted per platform per scheduler run.
MAX_APPLICATIONS_PER_RUN=10
# Fill forms but do NOT click final submit — set true to test the flow safely.
AUTOMATION_DRY_RUN=false
